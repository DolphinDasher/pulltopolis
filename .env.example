# Server-only GitHub token. Do not use a query parameter or expose it to Vite.
GITHUB_TOKEN=

HOST=127.0.0.1
PORT=3000
DATABASE_PATH=data/pulltopolis.sqlite

# Public-host settings. Keep TRUST_PROXY=0 for direct local development.
TRUST_PROXY=0
REQUEST_WINDOW_MS=60000
REQUEST_LIMIT_PER_IP=60
REQUEST_LIMIT_PER_LOGIN=20

# Optional hosted SQLite-compatible database. Configure both values together.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your_server_only_token

GITHUB_REQUEST_TIMEOUT_MS=10000
GITHUB_RATE_LIMIT_RESERVE=100
